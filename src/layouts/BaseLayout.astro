---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Shared page shell: <head> (SEO/OG/Twitter meta, fonts, favicons, analytics),
// navbar, mobile menu, and footer. Per-page meta comes in as props.
interface Props {
  title: string;
  description: string;
  url: string;
  /** Shorter title used for OG/Twitter cards; defaults to `title`. */
  ogTitle?: string;
  /** Homepage variant: transparent navbar, wordmark links to "#". */
  home?: boolean;
}

const { title, description, url, ogTitle = Astro.props.title, home = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- SEO -->
  <title>{title}</title>
  <meta name="author" content="Chouhan Industries">
  <meta name="description" content={description}>
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Chouhan Industries">
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={url}>
  <meta property="og:image" content="https://chouhan.ai/assets/images/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/png">
  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@chouhan_ai">
  <meta name="twitter:title" content={ogTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://chouhan.ai/assets/images/og-image.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
  <link rel="icon" type="image/x-icon" href="assets/favicons/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="assets/favicons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="assets/favicons/favicon-16x16.png">
  <link rel="icon" type="image/svg+xml" href="assets/favicons/logo-icon.svg">
  <link rel="apple-touch-icon" sizes="180x180" href="assets/favicons/apple-touch-icon.png">
  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FJ2H5WVSNV"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-FJ2H5WVSNV');
  </script>
</head>

<body>

  <Nav home={home} />

  <slot />

  <Footer home={home} />

  <script src="../scripts/site.js"></script>
</body>

</html>
