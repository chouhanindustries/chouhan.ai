---
import BaseLayout from '../layouts/BaseLayout.astro';

// Product index. Each entry links to a detail page in src/pages/products/;
// add a product by adding an entry here and a page there.
const products = [
  {
    href: 'products/open-media-platform.html',
    status: 'In Development',
    name: 'Open Media Platform',
    blurb:
      'A fully open, modular media computing platform. Every input, output, codec, and expansion module is replaceable and documented. Built for any medium, any format, any use case.',
  },
  {
    href: 'products/open-telegraph.html',
    status: 'In Development',
    name: 'Open Telegraph',
    blurb:
      'A pocket-size Morse key. One button, one RGB LED, an ESP32-S3, and a battery. Plug it in over USB-C or pair it over Bluetooth and it types Morse into any device as a standard keyboard.',
  },
  {
    href: 'products/open-clock.html',
    status: 'Planned',
    name: 'Open Clock',
    blurb:
      'A fully open, configurable clock. Choose the accuracy source (NTP, PTP, GPS, or atomic), the display panel (analog or digital), and the power supply, from solar to always-on AC. Every combination is documented and built to order.',
  },
  {
    href: 'products/open-purifier.html',
    status: 'Planned',
    name: 'Open Purifier',
    blurb:
      'A fully open, modular water purifier. Choose the filtration stages, from sediment and carbon to reverse osmosis and UV, and a monitoring core reads the water going in and coming out. Every cartridge is documented, refillable, and free of DRM.',
  },
];
---

<BaseLayout
  title="Products | Chouhan Industries | Open Hardware"
  ogTitle="Products | Chouhan Industries"
  description="Hardware designed for the public and built to the highest standard. Fully open schematics and documentation."
  url="https://chouhan.ai/products.html"
>

  <div class="page-hero">
    <div class="section-inner">
      <p class="eyebrow">What We Build</p>
      <h1>Products</h1>
      <p class="page-sub">Every product we release is fully documented and open. Schematics, tolerances, and process
        specifications are published before units ship.</p>
    </div>
  </div>

  <section class="page-section">
    <div class="section-inner">
      <div class="product-grid">
        {products.map((product) => (
          <a href={product.href} class="product-card" style="display: block; text-decoration: none;">
            <span class="status">{product.status}</span>
            <h2>{product.name}</h2>
            <p>{product.blurb}</p>
            <p
              style="margin-top: 20px; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold);">
              Learn More</p>
          </a>
        ))}
        <div class="product-card product-note">
          <p>More products to be announced. All design decisions are made in public. Follow the
            <a href="blog.html">build log</a> or check the <a href="open-source.html">repository</a> for progress.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section surface">
    <div class="section-inner">
      <div class="about-body">
        <div class="lead">Where this is going.</div>
        <div class="detail">
          <p>Every product here is a step toward one goal: consumer hardware you <em>truly own</em>. Fully open,
            <em>customizable</em> down to the source, and yours to build from the files, adapt to your needs, or
            simply buy finished.</p>
          <p>The complete design is published before units ship, so nothing you buy is ever a black box.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
